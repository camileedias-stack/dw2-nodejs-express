<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Produtos</title>
</head>
<body>
    <h1>Bem-vindo aos seus produtos</h1>
    <hr>
    <h3>Confira nossos produtos!</h3>

    <% listaProdutos.forEach(function(produto) { %>
        <p>
            <a href="/produtos/<%= produto %>">
                <%= produto %>
            </a>
        </p>
    <% }); %>

    <p><a href="/">Voltar para a página inicial</a></p>

</body>
</html>